            id INTEGER PRIMARY KEY AUTOINCREMENT,
            tribe_id INTEGER NOT NULL,
            clan_name TEXT NOT NULL,
            sub_clans TEXT,
            FOREIGN KEY (tribe_id) REFERENCES tribes(id),
